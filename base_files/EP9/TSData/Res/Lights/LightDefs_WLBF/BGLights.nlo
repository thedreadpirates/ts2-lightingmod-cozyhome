create Seven(gardenUplight)
lightAttribOverride gardenUplight coneAngle 35
lightAttribOverride gardenUplight conePenumbra 25
create SoftWhite(gardenUplight)

create Seven(gardenUplight_tree)
lightAttribOverride gardenUplight_tree diffusionSourceIntensity 0
lightAttribOverride gardenUplight_tree falloffRate 0.4
create SoftWhite(gardenUplight_tree)


######### Table lights ###########

create 45WattTABLE(lightingTableUnderwater_light)
lightAttribOverride lightingTableUnderwater_light color (.6,.8,.9)
lightAttribOverride lightingTableUnderwater_light diffusionSourceColor (.6,.8,.9)

create 45WattTABLE(lightingTableFantasy_light)
create SoftAmber(lightingTableFantasy_light)
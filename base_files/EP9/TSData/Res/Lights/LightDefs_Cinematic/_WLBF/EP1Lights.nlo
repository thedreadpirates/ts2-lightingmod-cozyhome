######### LIGHTS ####################

######## Ceiling Lights ###############

#8 Orbs of Connectedness #
create 150WattOVER(lightingCeilingGroovy_light)
create candleflame(lightingCeilingHangingFluorescent_light)

########### Floor lights ############

#4 Circle of Light Friendship Lamp #
create 75WattFL4(lightingFloorGroovy_light)
create candleflame(lightingFloorGroovy_light)

create largeCANDLEHIGH(lightingFloorMedieval_light)
create candleflame(lightingFloorMedieval_light)

######### OUTDOOR lights ##########

######### Table lights ###########

create largeCANDLEHIGH(lightingTableMedieval_light)
create candleflame(lightingTableMedieval_light)

######### Wall lights ##########

create largeCANDLE2WALL(lightingWallMedieval_light)
create candleflame(lightingWallMedieval_light)


######## Special Objects ###############

# Arcade Game #
#########################################
create 15-Watt(arcadeGame_light)
create LED(arcadeGame_light)

lightAttribOverride arcadeGame_light diffusionSourceMin  (0,1)
lightAttribOverride arcadeGame_light diffusionSourceMax (0,1)
lightAttribOverride arcadeGame_light diffusionSourceWallIntensityScale 2
lightAttribOverride arcadeGame_light diffusionSourceFloorIntensityScale .3

# Vending Kiosk
############################
create 20-Watt(vendingKiosk_light)
create 20-Watt(vendingKiosk_light1)
create LED(vendingKiosk_light)
create LED(vendingKiosk_light1)

lightAttribOverride vendingKiosk_light diffusionSourceMin  (0,1)
lightAttribOverride vendingKiosk_light diffusionSourceMax (0,1)
lightAttribOverride vendingKiosk_light1 diffusionSourceMin  (0,1)
lightAttribOverride vendingKiosk_light1 diffusionSourceMax (0,1)

